# Copy this file to .env. Development fetches this source into vendor/AstrBot.
ASTRBOT_SOURCE_GIT_URL=https://github.com/AstrBotDevs/AstrBot.git
ASTRBOT_SOURCE_GIT_REF=master

# Optional development overrides:
# ASTRBOT_SOURCE_DIR=../AstrBot
# ASTRBOT_BACKEND_TIMEOUT_MS=20000
# ASTRBOT_DASHBOARD_PORT=6185
